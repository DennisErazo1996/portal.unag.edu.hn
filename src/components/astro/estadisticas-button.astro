---
import { ChartColumnBig, X } from '@lucide/astro'
---


<button
  id="estadisticas-btn"
  class="fixed bottom-6 text-sm left-6 z-50 bg-unag-dark-green border-2 border-unag-light-green hover:bg-unag-dark-green text-white rounded-full p-4 shadow-lg transition-all duration-300 hover:scale-110 flex items-center gap-2 group"
  aria-label="Ver estadísticas de estudiantes"
>
  <ChartColumnBig class="w-6 h-6" />
  <span class="hidden group-hover:inline-block whitespace-nowrap">
    Estadísticas
  </span>
</button>

<!-- Modal -->
<div
  id="estadisticas-modal"
  class="fixed inset-0 bg-black/60 z-[20] hidden items-center justify-center p-4 backdrop-blur-sm"
>
  <div
    class="bg-white rounded-lg shadow-2xl w-full max-w-6xl h-[80vh] flex flex-col animate-fade-in"
  >
    <!-- Header del modal -->
    <div class="flex items-center justify-between p-4 border-b border-gray-200">
      <h2 class="text-lg md:text-lg text-unag-dark-green flex items-center gap-2">
        <ChartColumnBig class="w-6 h-6" />
        Estadísticas UNAG
      </h2>
      <button
        id="close-modal-btn"
        class="text-gray-500 hover:text-gray-700 transition-colors p-2 hover:bg-gray-100 rounded-full"
        aria-label="Cerrar modal"
      >
        <X class="w-6 h-6" />
      </button>
    </div>

    <!-- Contenedor del iframe -->
    <div class="flex-1 overflow-hidden relative bg-gray-100">
      <!-- Loader mientras carga el iframe -->
      <div
        id="iframe-loader"
        class="absolute inset-0 bg-white flex items-center justify-center z-10 transition-opacity duration-300"
      >
        <div class="text-center">
          <div class="inline-block animate-spin rounded-full h-12 w-12 border-4 border-unag-green border-t-transparent"></div>
          <p class="mt-4 text-gray-600 font-medium">Cargando estadísticas...</p>
        </div>
      </div>
      
      <iframe
        id="estadisticas-iframe"
        src="https://sys.unag.edu.hn/estadistica"
        class="w-full h-full border-0 relative z-0"
        title="Estadísticas de Estudiantes UNAG"
        allow="fullscreen"
      ></iframe>
    </div>
  </div>
</div>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.2s ease-out;
  }

  /* Mejoras de accesibilidad */
  #estadisticas-btn:focus-visible,
  #close-modal-btn:focus-visible {
    outline: 2px solid var(--color-unag-green);
    outline-offset: 2px;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    #estadisticas-modal > div {
      max-width: 100%;
      height: 95vh;
      margin: 0;
      border-radius: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    #estadisticas-btn {
      bottom: 1rem;
      left: 1rem;
      padding: 0.75rem;
    }

    #estadisticas-btn svg {
      width: 1.25rem;
      height: 1.25rem;
    }
  }
</style>

<script>
  const modal = document.getElementById('estadisticas-modal');
  const openBtn = document.getElementById('estadisticas-btn');
  const closeBtn = document.getElementById('close-modal-btn');
  const iframe = document.getElementById('estadisticas-iframe') as HTMLIFrameElement;
  const loader = document.getElementById('iframe-loader');

  // Abrir modal
  openBtn?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    document.body.style.overflow = 'hidden'; // Prevenir scroll del body
    
    // Cargar iframe solo cuando se abre el modal (lazy loading)
    if (iframe && !iframe.src) {
      iframe.src = 'https://sys.unag.edu.hn/estadistica';
    }
    
    // Ocultar loader después de 2 segundos
    if (loader) {
      setTimeout(() => {
        loader.style.opacity = '0';
        setTimeout(() => {
          loader.style.display = 'none';
        }, 300);
      }, 2000);
    }
  });

  // Cerrar modal
  const closeModal = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = ''; // Restaurar scroll
  };

  closeBtn?.addEventListener('click', closeModal);

  // Cerrar al hacer click fuera del contenido
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });

  // Cerrar con tecla Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('flex')) {
      closeModal();
    }
  });
</script>
