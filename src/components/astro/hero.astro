---
import {Image} from 'astro:assets'
import {Play} from '@lucide/astro';
import GlassIcons from '@/components/react/GlassIcons';

import hojaDesenfocada from "@assets/img/hojas/hoja-desenfocada.webp";
import hojaDesencadda02 from "@assets/img/hojas/hoja-desenfocada-02.webp";

---

<section
  id="hero"
  class="w-full h-screen relative overflow-hidden"
>
  <!-- Slide 1 - Original -->
  <div class="hero-slide active absolute inset-0 bg-[url('/img/slide-aprender-haciendo-03.jpg')] dark:bg-[url('/img/bg-default-unag.webp')] bg-center bg-no-repeat bg-cover flex pt-55 pl-3 lg:pl-20">
    <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/30 to-black/10 dark:from-black/90 dark:via-black/40 dark:to-black/30"></div>
    <div id="hojas-hero">
      <div
        class="absolute z-1 bottom-30 lg:translate-y-0 lg:bottom-10 -translate-x-20 lg:-translate-x-50 select-none rellax"
      >
        <Image
          class="w-30 lg:w-65"
          loading="lazy"
          src={hojaDesenfocada}
          alt="UNAG Logo"
          aria-hidden="true"
          decoding="async"
          fetchpriority="low"
        />
      </div>
      <div class="absolute z-1 right-0 lg:right-10 translate-x-20 rotate-180 translate-y-8 lg:translate-y-0 select-none rellax">
        <Image
          class="w-30 lg:w-40"
          loading="lazy"
          src={hojaDesencadda02}
          alt="UNAG Logo"
          aria-hidden="true"
          decoding="async"
          fetchpriority="low"
        />
      </div>
    </div>

    <div class="absolute inset-0 bg-black/40 z-0"></div>
    <div class="relative z-1 pl-4 min-[1280px]:scale-100 min-[2560px]:scale-150 origin-top-left">
      <p class="text-white text-xl lg:text-[35px]">BIENVENIDOS A LA</p>
      <p class="text-white font-extrabold text-4xl lg:text-[70px] leading-none">
        UNIVERSIDAD NACIONAL
      </p>
      <p class="text-white font-extrabold mb-6 text-3xl lg:text-[70px] mt-1 lg:mt-0">
        DE <span class="bg-unag-dark-green text-unag-light-green lg:py-0 px-2 lg:px-5"
          >AGRICULTURA</span>
      </p>
      <div class="flex items-center gap-6">
          <button id="btn-video-institucional" class="relative bg-unag-green p-4 rounded-full hover:scale-110 transition-transform duration-300 group">
              <Play size={20} class="text-white relative z-10" />
              <span class="absolute inset-0 rounded-full bg-unag-green animate-ping opacity-75"></span>
              <span class="absolute inset-0 rounded-full bg-unag-green animate-pulse opacity-50"></span>
          </button>
          <a
            href="/acerca/historia/"
            class="bg-transparent border-2 text-white py-2 px-6 rounded-full hover:bg-white hover:text-unag-dark-green transition-colors duration-300"
            >Nosotros</a
          >
      </div>
    </div>
  </div>

  

  <!-- Navegación con dots -->
  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-3">
    <button class="hero-dot active w-2 h-2 lg:w-3 lg:h-3 rounded-full bg-white transition-all duration-300" data-slide="0"></button>
    <!-- <button class="hero-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white/80 transition-all duration-300" data-slide="1"></button>
    <button class="hero-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white/80 transition-all duration-300" data-slide="2"></button> -->
  </div>

  <!-- Acceso Rápido -->
  <div class="absolute right-5 z-5 -bottom-1 lg:right-15 lg:bottom-10 justify-items-end scale-100 min-[1280px]:scale-80 min-[2560px]:scale-105 origin-right">
     <p class="text-sm lg:text-md text-white translate-y-7 lg:translate-y-0">Acceso Rápido:</p>
    <GlassIcons className="custom-class"/>
  </div>


</section>

<!-- Video Modal -->
<div id="videoModal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
  <div class="relative w-full max-w-4xl mx-4 bg-white rounded-2xl shadow-2xl overflow-hidden transform transition-all duration-300 scale-95 opacity-0">
    <!-- Modal Header -->
    <div class="flex items-center justify-between p-6 border-b border-gray-200">
      <h3 class="text-lg font-semibold text-gray-900">Video Institucional UNAG</h3>
      <button id="closeVideoModal" class="p-2 hover:bg-gray-100 rounded-full transition-colors duration-200">
        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- Video Container -->
    <div class="relative w-full" style="padding-bottom: 56.25%; /* 16:9 aspect ratio */">
      <iframe 
        id="youtubeIframe"
        class="absolute inset-0 w-full h-full"
        src=""
        title="Video Institucional UNAG"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen>
      </iframe>
    </div>
  </div>
</div>

<script>
  class HeroSlideshow {
    private currentSlide: number;
    private slides: NodeListOf<Element>;
    private dots: NodeListOf<Element>;
    private totalSlides: number;
    private autoPlayInterval: ReturnType<typeof setInterval> | null;
    private autoPlayDelay: number;

    constructor() {
      this.currentSlide = 0;
      this.slides = document.querySelectorAll('.hero-slide');
      this.dots = document.querySelectorAll('.hero-dot');
      this.totalSlides = this.slides.length;
      this.autoPlayInterval = null;
      this.autoPlayDelay = 5000;
      
      this.init();
    }

    init(): void {
      // Dot navigation
      this.dots.forEach((dot: Element, index: number) => {
        dot.addEventListener('click', () => this.goToSlide(index));
      });

      // Auto-play
      this.startAutoPlay();

      // Pause auto-play on hover
      const heroSection = document.getElementById('hero');
      heroSection?.addEventListener('mouseenter', () => this.stopAutoPlay());
      heroSection?.addEventListener('mouseleave', () => this.startAutoPlay());

      // Video modal functionality
      this.initVideoModal();
    }

    initVideoModal(): void {
      const playBtn = document.getElementById('btn-video-institucional');
      const modal = document.getElementById('videoModal');
      const closeBtn = document.getElementById('closeVideoModal');
      const iframe = document.getElementById('youtubeIframe') as HTMLIFrameElement;
      
      const videoUrl = 'https://www.youtube.com/embed/W3YL0tmk2hg?autoplay=1&rel=0';
      
      // Open modal
      playBtn?.addEventListener('click', () => {
        if (modal && iframe) {
          iframe.src = videoUrl;
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          
          
          setTimeout(() => {
            const modalContent = modal.querySelector('div');
            modalContent?.classList.remove('scale-95', 'opacity-0');
            modalContent?.classList.add('scale-100', 'opacity-100');
          }, 10);
          
          
          this.stopAutoPlay();
        }
      });
      
      // Close modal function
      const closeModal = () => {
        if (modal && iframe) {
          const modalContent = modal.querySelector('div');
          modalContent?.classList.remove('scale-100', 'opacity-100');
          modalContent?.classList.add('scale-95', 'opacity-0');
          
          setTimeout(() => {
            modal.classList.remove('flex');
            modal.classList.add('hidden');
            iframe.src = ''; // Stop video
          }, 300);
          
          // Resume slideshow when modal closes
          this.startAutoPlay();
        }
      };
      
      // Close modal events
      closeBtn?.addEventListener('click', closeModal);
      
      // Close on backdrop click
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal();
        }
      });
      
      // Close on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
          closeModal();
        }
      });
    }

    goToSlide(index: number): void {
      // Hide current slide
      this.slides[this.currentSlide]?.classList.remove('active');
      this.dots[this.currentSlide]?.classList.remove('active', 'bg-white');
      this.dots[this.currentSlide]?.classList.add('bg-white/50');

      // Update current slide
      this.currentSlide = index;

      // Show new slide
      this.slides[this.currentSlide]?.classList.add('active');
      this.dots[this.currentSlide]?.classList.remove('bg-white/50');
      this.dots[this.currentSlide]?.classList.add('active', 'bg-white');
    }

    nextSlide(): void {
      const nextIndex = (this.currentSlide + 1) % this.totalSlides;
      this.goToSlide(nextIndex);
    }

    startAutoPlay(): void {
      this.stopAutoPlay();
      this.autoPlayInterval = setInterval(() => {
        this.nextSlide();
      }, this.autoPlayDelay);
    }

    stopAutoPlay(): void {
      if (this.autoPlayInterval) {
        clearInterval(this.autoPlayInterval);
        this.autoPlayInterval = null;
      }
    }
  }

  // Initialize slideshow when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new HeroSlideshow();
  });
</script>

<style>
  .hero-slide {
    opacity: 0;
    transition: opacity 1s ease-in-out;
    pointer-events: none;
  }

  .hero-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero-dot.active {
    transform: scale(1.2);
  }

  
  .hero-slide {
    background-size: cover;
  }

  /* Desktop zoom animation */
  @media (min-width: 769px) {
    .hero-slide {
      animation: zoomIn 10s ease-out infinite alternate;
    }
    
    @keyframes zoomIn {
      0% {
        background-size: 100%;
      }
      100% {
        background-size: 110%;
      }
    }
  }

  /* Mobile-specific hero adjustments */
  @media (max-width: 768px) {
    #hero {
      min-height: 100vh;
      min-height: 100dvh;
    }
    
    .hero-slide {
      background-position: center center;
      background-size: cover !important;
      min-height: 100vh;
      min-height: 100dvh;
      animation: none;
    }
  }
</style>
