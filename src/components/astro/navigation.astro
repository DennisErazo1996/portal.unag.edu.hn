<nav class="flex lg:justify-center lg:items-center w-full text-white z-20 scale-100 min-[1280px]:scale-90 min-[2560px]:scale-110 py-2">
    
    <div class="hidden lg:flex items-center">
        <div id="logo-unag" class="bg-unag-dark-green px-20 py-4 ">
