                    class="lg:w-45"
                    src={logoUnagBlanco}
                    alt="UNAG Logo"
                    loading="eager"
                  />
            </a>
        </div>
        <div class="flex items-center bg-unag-green h-13 p-5 h-15 overflow-visible relative border-b-4 border-r-4 border-unag-dark-green">
