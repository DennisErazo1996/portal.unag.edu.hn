---
import { Image } from "astro:assets";
import { Menu, ChevronDown } from "@lucide/astro";

import logoUnagBlanco from "@assets/img/logo-unag-blanco.png";
import LinkDropdownMenu from "@/components/astro/navigation/link-dropdown-menu.astro";
import DropdownMenuContainer from "@/components/astro/navigation/dropdown-menu-container.astro";
import DropdownMenuItemWithSubmenu from "@/components/astro/navigation/dropdown-menu-item-with-submenu.astro";
import SubmenuLink from "@/components/astro/navigation/submenu-link.astro";
import NAV_ITEMS from '@/consts/navigation';
import type { NavDropdown } from '@/types/navigation';
import carreras from '@/consts/carreras';
---


<nav class="flex lg:justify-center lg:items-center w-full text-white z-20 scale-100 min-[1280px]:scale-90 min-[2560px]:scale-110 py-2 hover:scale-[0.93] transition-transform duration-300">
    
    <div class="hidden lg:flex items-center gap-5">
        <div id="logo-unag" class="bg-unag-dark-green px-20 py-3 rounded-full">
            <a href="/" class="block ">
                 <Image    
                    class="lg:w-45"
                    src={logoUnagBlanco}
                    alt="UNAG Logo"
                    loading="eager"
                  />
            </a>
        </div>
        <div class="flex items-center bg-unag-green h-13 p-5 overflow-visible relative border-b-4 border-r-4 border-unag-dark-green rounded-full">
            <ul class="flex gap-5">
              {NAV_ITEMS.map((item) => {
                if (item.type === 'link') {
                  return (
                    <li>
                      <a href={item.href} target={item.target} class="hover:text-unag-yellow transition-colors">
                        {item.label}
                      </a>
                    </li>
                  );
                }

                if (item.type === 'carreras') {
                  return (
                    <li class="relative group">
                      <button class="flex items-center gap-1 hover:text-unag-yellow transition-colors">
                        Carreras <ChevronDown size={14} class="transition-transform group-hover:rotate-180 duration-300" />
                      </button>
                      <DropdownMenuContainer>
                        {carreras.map((carrera) => (
                          <LinkDropdownMenu href={carrera.link}>{carrera.nombre}</LinkDropdownMenu>
                        ))}
                      </DropdownMenuContainer>
                    </li>
                  );
                }

                const dropdown = item as NavDropdown;
                return (
                  <li class="relative group">
                    <button class="flex items-center gap-1 hover:text-unag-yellow transition-colors">
                      {dropdown.label} <ChevronDown size={14} class="transition-transform group-hover:rotate-180 duration-300" />
                    </button>
                    <DropdownMenuContainer>
                      {dropdown.children.map((child) => {
                        if (child.type === 'group') {
                          return (
                            <DropdownMenuItemWithSubmenu title={child.title}>
                              {child.children.map((link) => (
                                <SubmenuLink href={link.href} target={link.target}>{link.label}</SubmenuLink>
                              ))}
                            </DropdownMenuItemWithSubmenu>
                          );
                        }
                        return (
                          <LinkDropdownMenu href={child.href} target={child.target}>{child.label}</LinkDropdownMenu>
                        );
                      })}
                    </DropdownMenuContainer>
                  </li>
                );
              })}
            </ul>
        </div>
    </div>

   
    <div class="lg:hidden mt-3 mb-3 ml-6">
        <div class="flex items-center gap-5">
            <button id="menu-toggle" class="bg-unag-green p-3 rounded-lg">
            <Menu size={24} />
            </button>
             <a href="/">
                <Image
                    class="w-35"
                    src={logoUnagBlanco}
                    alt="UNAG Logo"
                    loading="eager"
                />
            </a>
        </div>
    </div>

</nav>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('mobile-overlay');

  function openDrawer() {
    drawer?.classList.remove('-translate-x-full');
    overlay?.classList.remove('opacity-0', 'invisible');
    overlay?.classList.add('opacity-100', 'visible');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.add('-translate-x-full');
    overlay?.classList.add('opacity-0', 'invisible');
    overlay?.classList.remove('opacity-100', 'visible');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openDrawer);
  menuClose?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);
</script>