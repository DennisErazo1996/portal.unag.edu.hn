---
import {
  ChevronDown,
  Home,
  Newspaper,
  Info,
  Building2,
  Server,
  GraduationCap,
  BookOpen,
  Eye,
  UserPlus,
  FlaskConical,
  Award,
  X,
} from "@lucide/astro";
import { Image } from "astro:assets";
import logoUnagBlanco from "@assets/img/logo-unag-blanco.png";
import NAV_ITEMS from '@/consts/navigation';
import type { NavDropdown } from '@/types/navigation';
import carreras from "@/consts/carreras";

const ICON_MAP = {
  Home, Newspaper, Info, Building2, Server,
  GraduationCap, BookOpen, Eye, UserPlus, FlaskConical, Award,
} as const;

type IconName = keyof typeof ICON_MAP;

function getIcon(name: string | undefined): IconName | null {
  if (!name || !(name in ICON_MAP)) return null;
  return name as IconName;
}
---

<section class="text-white text-[12px]">
  <div
    id="mobile-overlay"
    class="fixed inset-0 bg-black/50 opacity-0 invisible transition-all duration-300"
  >
  </div>

  <div
    id="mobile-drawer"
    class="z-50 fixed top-0 left-0 w-75 h-full bg-unag-dark-green dark:bg-background transform -translate-x-full transition-transform duration-300 ease-out shadow-2xl"
    style="z-index: 9999 !important;"
  >
    <div
      class="flex justify-between items-center p-5 border-b-2 border-unag-green"
    >
      <a href="/">
        <Image
          src={logoUnagBlanco}
          alt="Logo UNAG"
          loading="eager"
          class="w-35"
        />
      </a>
      <button id="menu-close" class="hover:text-unag-yellow transition-colors">
        <X size={24} />
      </button>
    </div>
    <ul class="flex flex-col p-4 gap-1 overflow-y-auto max-h-[calc(100vh-100px)] text-white">
      {NAV_ITEMS.map((item) => {
        const iconName = getIcon(item.icon);
        const IconComponent = iconName ? ICON_MAP[iconName] : null;

        if (item.type === 'link') {
          return (
            <li>
              <a
                href={item.href}
                target={item.target}
                class="flex items-center gap-3 py-2.5 px-3 rounded-lg hover:bg-unag-green/30 hover:text-unag-yellow transition-all font-medium"
              >
                {IconComponent && <IconComponent size={20} />}
                <span>{item.label}</span>
              </a>
            </li>
          );
        }

        if (item.type === 'carreras') {
          return (
            <li>
              <button class="mobile-dropdown-toggle w-full flex items-center justify-between py-2.5 px-3 rounded-lg hover:bg-unag-green/30 hover:text-unag-yellow transition-all font-medium">
                <div class="flex items-center gap-3">
                  {IconComponent && <IconComponent size={20} />}
                  <span>Carreras</span>
                </div>
                <ChevronDown size={18} class="transition-transform duration-300" />
              </button>
              <ul class="mobile-dropdown-content max-h-0 overflow-hidden transition-all duration-300 ease-out">
                {carreras.map((carrera) => (
                  <li>
                    <a href={carrera.link} class="block py-2 pl-11 hover:text-unag-yellow transition-colors">
                      {carrera.nombre}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          );
        }

        const dropdown = item as NavDropdown;
        return (
          <li>
            <button class="mobile-dropdown-toggle w-full flex items-center justify-between py-2.5 px-3 rounded-lg hover:bg-unag-green/30 hover:text-unag-yellow transition-all font-medium">
              <div class="flex items-center gap-3">
                {IconComponent && <IconComponent size={20} />}
                <span>{dropdown.label}</span>
              </div>
              <ChevronDown size={18} class="transition-transform duration-300" />
            </button>
            <ul class="mobile-dropdown-content max-h-0 overflow-hidden transition-all duration-300 ease-out">
              {dropdown.children.map((child) => {
                if (child.type === 'group') {
                  return (
                    <li>
                      <button class="mobile-submenu-toggle w-full flex items-center justify-between py-2 pl-11 hover:text-unag-yellow transition-colors">
                        <span>{child.title}</span>
                        <ChevronDown size={14} class="transition-transform duration-300" />
                      </button>
                      <ul class="mobile-submenu-content max-h-0 overflow-hidden transition-all duration-300 ease-out">
                        {child.children.map((link) => (
                          <li>
                            <a
                              href={link.href}
                              target={link.target}
                              class="block py-1.5 pl-16 hover:text-unag-yellow transition-colors"
                            >
                              {link.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </li>
                  );
                }
                return (
                  <li>
                    <a
                      href={child.href}
                      target={child.target}
                      class="block py-2 pl-11 hover:text-unag-yellow transition-colors"
                    >
                      {child.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const dropdownToggles = document.querySelectorAll(
      ".mobile-dropdown-toggle"
    );

    dropdownToggles.forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.preventDefault();
        const content = toggle.nextElementSibling;
        const svgs = toggle.querySelectorAll("svg");
        const chevron = svgs[svgs.length - 1]; // Último SVG es el ChevronDown
        const isOpen = content?.classList.contains("max-h-[1000px]");

        // Cerrar todos los otros dropdowns
        document
          .querySelectorAll(".mobile-dropdown-content")
          .forEach((item) => {
            if (item !== content) {
              item.classList.remove("max-h-[1000px]");
              item.classList.add("max-h-0");
              const otherToggle = item.previousElementSibling;
              const otherSvgs = otherToggle?.querySelectorAll("svg");
              const otherChevron = otherSvgs?.[otherSvgs.length - 1];
              otherChevron?.classList.remove("rotate-180");
            }
          });

        // Toggle del dropdown actual
        if (isOpen) {
          content?.classList.remove("max-h-[1000px]");
          content?.classList.add("max-h-0");
          chevron?.classList.remove("rotate-180");
        } else {
          content?.classList.remove("max-h-0");
          content?.classList.add("max-h-[1000px]");
          chevron?.classList.add("rotate-180");
        }
      });
    });

    // Submenús
    const submenuToggles = document.querySelectorAll(".mobile-submenu-toggle");

    submenuToggles.forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const content = toggle.nextElementSibling;
        const chevron = toggle.querySelector("svg");
        const isOpen = content?.classList.contains("max-h-[500px]");

        // Toggle del submenú actual
        if (isOpen) {
          content?.classList.remove("max-h-[500px]");
          content?.classList.add("max-h-0");
          chevron?.classList.remove("rotate-180");
        } else {
          content?.classList.remove("max-h-0");
          content?.classList.add("max-h-[500px]");
          chevron?.classList.add("rotate-180");
        }
      });
    });
  });
</script>
