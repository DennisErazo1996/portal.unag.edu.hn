---
const { title } = Astro.props;
---

<div class="relative group/submenu static">
  <button
    class="flex items-center justify-between w-full px-5 py-3 hover:bg-unag-dark-green hover:rounded-full hover:text-white transition-all duration-200 transform hover:translate-x-1"
  >
    <span>{title}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-4 w-4 transition-transform group-hover/submenu:rotate-90 duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>
  
  <!-- Submenu -->
  <div
    class="absolute left-full top-0 w-56 ml-2 invisible opacity-0 group-hover/submenu:visible group-hover/submenu:opacity-100 transition-all duration-300 transform translate-x-2 group-hover/submenu:translate-x-0 pointer-events-none group-hover/submenu:pointer-events-auto z-[100]"
  >
    <div class="bg-white text-unag-dark-green rounded-lg shadow-2xl w-fit py-3 pr-5 border-l-4 border-unag-dark-green overflow-hidden mt-10">
      <slot />
    </div>
  </div>
</div>
