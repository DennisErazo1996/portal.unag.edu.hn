---
const { title } = Astro.props;
---

<div class="submenu-parent relative static">
  <button
    class="submenu-toggle flex items-center justify-between w-full px-5 py-3 hover:bg-unag-dark-green dark:hover:bg-unag-green hover:rounded-full hover:text-white transition-all duration-200 transform hover:translate-x-1"
  >
    <span>{title}</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="submenu-chevron h-4 w-4 transition-transform duration-300"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>
  
  <!-- Submenu -->
  <div
    class="submenu-content absolute left-full top-0 w-56 ml-2 invisible opacity-0 transition-all duration-300 transform translate-x-2 pointer-events-none z-[100]"
  >
    <div class="bg-white dark:bg-unag-dark-green text-unag-dark-green dark:text-white rounded-lg shadow-2xl w-fit py-3 pr-5 border-l-4 border-unag-dark-green overflow-hidden mt-10">
      <slot />
    </div>
  </div>
</div>

<style>
    .submenu-content.active {
        visibility: visible;
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
    }
    
    .submenu-chevron.rotated {
        transform: rotate(90deg);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const submenuParents = document.querySelectorAll('.submenu-parent');
        
        submenuParents.forEach(parent => {
            const toggle = parent.querySelector('.submenu-toggle') as HTMLElement;
            const submenu = parent.querySelector('.submenu-content') as HTMLElement;
            const chevron = parent.querySelector('.submenu-chevron') as HTMLElement;
            
            if (!toggle || !submenu) return;
            
            // Toggle con click
            toggle.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                
                const isActive = submenu.classList.contains('active');
                
                // Cerrar otros submenús
                document.querySelectorAll('.submenu-content.active').forEach(other => {
                    if (other !== submenu) {
                        other.classList.remove('active');
                        const otherChevron = other.parentElement?.querySelector('.submenu-chevron');
                        otherChevron?.classList.remove('rotated');
                    }
                });
                
                // Toggle del submenú actual
                if (isActive) {
                    submenu.classList.remove('active');
                    chevron?.classList.remove('rotated');
                } else {
                    submenu.classList.add('active');
                    chevron?.classList.add('rotated');
                }
            });
        });
        
        // Cerrar submenús al hacer click fuera
        document.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (!target.closest('.submenu-parent')) {
                document.querySelectorAll('.submenu-content.active').forEach(submenu => {
                    submenu.classList.remove('active');
                    const chevron = submenu.parentElement?.querySelector('.submenu-chevron');
                    chevron?.classList.remove('rotated');
                });
            }
        });
    });
</script>
