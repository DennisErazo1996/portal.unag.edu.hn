---

interface Props{
    numero: string;
    proceso: string;
    fechas: { fecha: string; descripcion: string; marcado?: boolean }[];
    localidades: string[];
    finalizado?: boolean;
}

const { numero, proceso, fechas, localidades, finalizado = false } = Astro.props;

---

<article
  class={`group relative border rounded-2xl p-8 overflow-hidden transition-all duration-300 hover:-translate-y-1  backdrop-blur-sm bg-unag-dark-green ${
    finalizado
      ? 'border-white/[0.04] hover:border-white/[0.08] hover:shadow-gray-950/30 opacity-92'
      : 'border-white/[0.08] hover:border-green-600/40 hover:shadow-green-950/50'
  }`}
>

  <!-- Cabecera -->
  <div class="flex items-start gap-4 mb-8 relative">
    <div
      class="shrink-0 w-12 h-12 rounded-xl bg-unag-green flex items-center justify-center"
    >
      <span class="font-extrabold text-white text-sm tracking-tight">{numero}</span>
    </div>
    <div>
      <span
        class="block text-xs font-medium tracking-widest uppercase text-green-400/70 mb-1"
        >{proceso} Proceso de</span
      >
      <h3 class="font-extrabold text-2xl text-white tracking-tight">
        Admisión
      </h3>
      {finalizado && (
        <span class="inline-block mt-2 text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full bg-white/10 text-white/40 border border-white/10">
          Proceso finalizado
        </span>
      )}
    </div>
  </div>

  <!-- Timeline -->
  <div class="relative mb-8">
    <div
      class="absolute left-[7px] top-2 bottom-2 w-px bg-unag-yellow"
    >
    </div>

    <ul class="space-y-6">
      {fechas.map(({ fecha, descripcion, marcado }) => (
        <li class="relative pl-8">
          <div
            class={`absolute left-0 top-0 w-4 h-4 rounded-full border-2 border-unag-green ${
              marcado ? 'bg-unag-yellow border-unag-yellow' : 'bg-green-950'
            } border border-green-600/50`}
          ></div>
          <div class="text-[12px] text-unag-green">{fecha}</div>
          <div class="text-sm font-medium text-white">{descripcion}</div>
        </li>
      ))}

  </div>

  <!-- Localidades -->
  <div class="border-t border-white/[0.07] pt-5">
    <h4
      class="flex items-center gap-1.5 text-xs font-bold uppercase text-unag-yellow mb-3"
    >
      <svg
        class="w-3.5 h-3.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle
          cx="12"
          cy="10"
          r="3"></circle></svg
      >
      Localidades
    </h4>
    <ul class="space-y-1.5">
      {
        localidades.map((loc) => (
          <li class="relative text-[13px] text-white/80 pl-3.5 leading-snug before:content-['—'] before:absolute before:left-0 before:text-unag-green before:text-[11px] before:top-0.5">
            {loc}
          </li>
        ))
      }
    </ul>
  </div>
</article>
