---
import { Image } from 'astro:assets';

interface Props {
  imagen?: string;
  etiqueta?: string;
  subetiqueta?: string;
  titulo: string;
}

const { imagen, etiqueta, subetiqueta, titulo } = Astro.props;

import hoja01 from '@assets/img/hojas/hoja-angulo-02.webp';
import hoja02 from '@assets/img/hojas/hoja-angulo-01.webp';
---

<section class="absolute z-5 inset-0 w-full flex justify-between pointer-events-none select-none overflow-hidden">
    <Image src={hoja01} alt="" class="w-20 h-20 md:w-38 md:h-38 lg:w-50 lg:h-50 -ml-10 mt-110 lg:-ml-20 lg:mt-80"/>
    <Image src={hoja02} alt="" class="w-20 h-20 md:w-38 md:h-38 lg:w-40 lg:h-40 -mr-5 mt-30 lg:-mr-10 lg:mt-20 rotate-90"/>
</section>

<header class="relative bg-unag-gray/30 overflow-hidden">
  <!-- Imagen de fondo -->
  {imagen && (
    <>
      <div class="absolute inset-0">
        <img 
          src={imagen} 
          alt="" 
          class="w-full h-full object-cover"
        />
      </div>
      
      <div class="absolute inset-0 bg-unag-gray/50"></div>
    </>
  )}
  
  <!-- Patrón decorativo sutil -->
  <div class="absolute inset-0 opacity-10 z-10 pointer-events-none">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgb(255, 255, 255) 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>
  
  <!-- Formas decorativas -->
  <div class="absolute inset-0 dark:bg-black/80"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-unag-green/50 rounded-full blur-[150px] -translate-y-1/2 translate-x-1/2 z-10"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-unag-green/50 rounded-full blur-[140px] translate-y-1/2 -translate-x-1/2 z-10"></div>
  
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-55 pb-24 z-20">
    <!-- Breadcrumb -->
    {(etiqueta || subetiqueta) && (
      <nav class="flex items-center gap-2 text-sm text-white/80 mb-6" aria-label="Breadcrumb">
        {etiqueta && (
          <>
            <span class="hover:text-white transition-colors">{etiqueta}</span>
            {subetiqueta && (
              <>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span class="hover:text-white transition-colors truncate">{subetiqueta}</span>
              </>
            )}
          </>
        )}
      </nav>
    )}
    
    <!-- Título -->
    <h1 class="flex items-center text-5xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight gap-3">
      {titulo} <span class="bg-[url('/img/unag-hoja.png')] bg-cover bg-center w-6 h-6 rotate-90 hidden lg:block"></span>
    </h1>
    
    <!-- Línea decorativa -->
    <div class="flex items-center">
        <div class="mt-6 w-20 h-[2px] bg-unag-green rounded-full"></div>
    </div>
  </div>
</header>
