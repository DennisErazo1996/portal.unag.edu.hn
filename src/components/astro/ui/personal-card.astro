---
import {Mail, Phone} from '@lucide/astro'

const {nombreCompleto, cargo, correo, nombre, apellido, telefono} = Astro.props;

const imagen = `https://ui-avatars.com/api/?name=${nombre}+${apellido}&size=200&background=1ba333&color=fff&bold=true`
---

<div
  class="bg-white rounded-2xl overflow-hidden shadow-lg border border-gray-100 hover:shadow-lg transition-all hover:-translate-y-1 mt-10"
>
  <div class="p-6">
    <div class="flex items-center gap-4 mb-4">
      <img
        src={imagen}
        alt={nombreCompleto}
        class="w-20 h-20 rounded-full object-cover border-4 border-unag-green/20"
      />
      <div class="flex-1">
        <h3 class="font-bold text-lg text-gray-800">
          {nombreCompleto}
        </h3>
        <p class="text-sm text-unag-green font-medium">
          {cargo}
        </p>
      </div>
    </div>
    
      {
        correo && (
          <div
            class="flex items-center gap-2 text-sm text-gray-600 bg-gray-50 p-3 rounded-lg"
          >
            <Mail class="w-4 h-4 text-unag-green" />
            <a
              href={`mailto:${correo}`}
              class="hover:text-unag-green transition-colors break-all"
            >
              {correo}
            </a>
          </div>
        )
      }
      {
        telefono && (
          <div
            class="flex items-center gap-2 text-sm text-gray-600 bg-gray-50 p-3 rounded-lg"
          >
          <Phone class="w-4 h-4 text-unag-green" />
          <a
            href={`tel:${telefono}`}
            class="hover:text-unag-green transition-colors break-all"
          >
            {telefono}
          </a>
          </div>
        )
      }
  </div>
</div>
