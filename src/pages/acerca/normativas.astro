---
import Layout from '@/layouts/main.astro';
import HeaderPages from '@/components/astro/ui/header-bg-pages.astro';
import { FileText, Download, Eye } from 'lucide-react';
import normativas from '@/consts/normativas';

const content = {
    title: 'Normativas | UNAG'
}


---

<Layout content={content}>
    <HeaderPages
        imagen="/img/bg-default-unag.webp"
        etiqueta="Acerca"
        titulo="Normativas"
        descripcion="La Universidad Nacional de Agricultura pone a disposición de la comunidad universitaria y el público en general las normativas vigentes que rigen nuestro funcionamiento, asegurando la transparencia y el orden institucional."
    />

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="mb-12 text-center max-w-3xl mx-auto">
            <h2 class="text-3xl font-bold text-unag-dark-green mb-4">Marco Normativo Institucional</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {normativas.map((doc) => (
                <div class="group relative bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-lg transition-all duration-300 flex flex-col h-full overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-unag-green transform origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-300"></div>
                    
                    <div class="p-6 flex-grow">
                        <div class="w-12 h-12 rounded-lg bg-unag-overlay-green text-unag-green flex items-center justify-center mb-4 group-hover:bg-unag-green group-hover:text-white transition-colors duration-300">
                            <FileText className="w-6 h-6" />
                        </div>
                        
                        <h3 class="text-lg font-bold text-gray-800 mb-2 group-hover:text-unag-green transition-colors">
                            {doc.title}
                        </h3>
                        
                        <p class="text-sm text-gray-500 mb-4 line-clamp-3">
                            {doc.description}
                        </p>
                        
                        <span class="inline-block px-2 py-1 bg-gray-50 text-xs font-medium text-gray-500 rounded-md">
                            {doc.date}
                        </span>
                    </div>

                    <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
                        <a 
                            href={doc.file} 
                            class="flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-unag-green transition-colors"
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            <Eye className="w-4 h-4" />
                            <span>Ver</span>
                        </a>
                        
                        <a 
                            href={doc.file} 
                            class="flex items-center gap-2 text-sm font-medium text-white bg-unag-green hover:bg-unag-dark-green px-3 py-1.5 rounded-md transition-colors shadow-sm"
                            download
                        >
                            <Download className="w-4 h-4" />
                            <span>Descargar</span>
                        </a>
                    </div>
                </div>
            ))}
        </div>
        
        <div class="mt-16 bg-unag-overlay-green rounded-2xl p-8 flex flex-col md:flex-row items-center justify-between gap-6 border border-unag-green/20">
            <div>
                <h3 class="text-xl font-bold text-unag-dark-green mb-2">¿No encuentras lo que buscas?</h3>
                <p class="text-gray-600 max-w-xl text-sm">
                    Para consultas específicas sobre documentación institucional o solicitudes de acceso a la información pública, puedes contactar a la Secretaría General.
                </p>
            </div>
            <a href="mailto:secretariageneral@unag.edu.hn" class="shrink-0 inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-white bg-unag-dark-green hover:bg-unag-green transition-colors shadow-md text-sm">
                Contactar Secretaría
            </a>
        </div>
    </section>
</Layout>   