---
export const prerender = true;

import {
  ArrowUpRight,
  BellRing,
  BookOpenCheck,
  CalendarDays,
  CircleCheck,
  CreditCard,
  Download,
  FileSearch,
  Info,
  Users,
} from '@lucide/astro';
import Layout from '@/layouts/main.astro';
import HeaderPages from '@/components/astro/ui/header-bg-pages.astro';

const content = {
    title: 'Etapas del Proceso de Admisión | UNAG'
};

const stages = [
    {
        number: '01',
        title: 'Registro e inscripción',
        description:
            'Crea tu usuario y completa tu ficha de aspirante en el portal oficial.',
        badge: 'Obligatorio',
        icon: CircleCheck,
        links: [
            {
                label: 'Ir a inscripción',
                href: 'https://portal.unag.edu.hn/matricula/admisiones',
                external: true
            }
        ]
    },
    {
        number: '02',
        title: 'Pago por derecho a la prueba',
        description: 'Consulta el procedimiento para validar tu pago.',
        icon: CreditCard,
        links: [
            {
                label: 'Instrucciones de pago',
                href: '/admisiones/validacion-de-pago',
                external: false
            }
        ]
    },
    {
        number: '03',
        title: 'Aplicación de la prueba UNAG',
        description:
            'Prepárate para la evaluación presencial. Utiliza los siguientes recursos:',
        icon: BookOpenCheck,
        resources: [
            { label: 'Recursos descargables', href: 'https://drive.google.com/drive/folders/1NLg3KOTSeOXvnQziHgMSqEnMahE16MuZ', disabled: false },
            { label: 'Simulacros integral de prácticas', href: 'https://gemini.google.com/share/494faa9a218b', disabled: false },
            { label: 'Instrucciones para el día de la prueba', href: '/admisiones/validacion-de-pago', disabled: false }
        ]
    },
    {
        number: '04',
        title: 'Consulta resultados / selección carrera',
        description:
            'Consulta tus notas y selecciona tu carrera conforme al puntaje obtenido.',
        note: '*Disponibles hasta la fecha calendarizada.',
        icon: FileSearch,
        links: [
            {
                label: 'Ver resultados',
                href: 'https://portal.unag.edu.hn/matricula/admisiones/solicitudes/resultados',
                external: true
            }
        ]
    }
];
---

<Layout content={content}>
    <HeaderPages
        imagen="/img/bg-default-unag.webp"
        etiqueta="Admisiones"
        titulo="Etapas del Proceso de Admisión"
        descripcion="Conoce cada etapa del proceso de admisión y accede a los enlaces clave para completar tu postulación en la UNAG."
    />

    <section class="bg-white py-14 dark:bg-background">
        <div class="mx-auto max-w-full px-4 sm:px-6 lg:max-w-[85%] lg:px-8">
            <div class="rounded-lg border border-unag-light-gray bg-white p-5 dark:border-white/10 dark:bg-card sm:p-7">
                <div class="space-y-3 border-b border-unag-light-gray pb-5 dark:border-white/10">
                    <span class="inline-flex items-center gap-2 rounded-lg border border-unag-green/30 bg-unag-overlay-green px-3 py-1 text-sm font-semibold text-unag-dark-green dark:border-white/15 dark:bg-unag-dark-green dark:text-white">
                        <Info class="h-4 w-4" />
                        Proceso de admisión
                    </span>
                    <h2 class="text-xl font-extrabold tracking-tight text-unag-dark-green dark:text-white sm:text-2xl">
                        Etapas del proceso de admisión
                    </h2>
                    <p class="max-w-3xl text-sm leading-6 text-unag-gray/85 dark:text-white/75">
                        Sigue las etapas en orden para completar tu proceso. Este flujo aplica de forma general en cada convocatoria de admisión.
                    </p>
                </div>

                <div class="mt-5 grid grid-cols-2 gap-2 lg:gap-3 lg:grid-cols-5">
                    {['Registro', 'Pago', 'Aplicación', 'Resultados', 'Notificación'].map((label, idx) => (
                        <div class={`rounded-lg border ${idx == 4 ? 'col-span-2' : 'col-span-1'} lg:col-span-1  border-unag-light-gray bg-unag-light-gray px-3 py-2 text-center text-sm font-semibold text-unag-dark-green dark:border-white/10 dark:bg-background dark:text-white/85`}>
                            <span class="mr-1 text-unag-green">{idx + 1}.</span>{label}
                        </div>
                    ))}
                </div>

                <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_300px]">
                    <div class="space-y-4">
                        {
                            stages.map((stage) => (
                                <article class="rounded-lg border border-unag-light-gray bg-white p-4 text-sm dark:border-white/10 dark:bg-background">
                                    <div class="flex items-start gap-3">
                                        <div class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg  bg-unag-green font-black text-white dark:border-white/20 dark:bg-unag-dark-green dark:text-white">
                                            {stage.number}
                                        </div>

                                        <div class="min-w-0 flex-1">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <span class="inline-flex items-center gap-1 text-unag-green dark:text-unag-light-green">
                                                    <stage.icon class="h-4 w-4" />
                                                </span>
                                                <h3 class="text-base font-bold text-unag-dark-green dark:text-white">
                                                    {stage.title}
                                                </h3>
                                                {
                                                    stage.badge && (
                                                        <span class="inline-flex rounded-lg border border-unag-green/35 bg-unag-overlay-green px-2 py-0.5 text-[11px] font-semibold uppercase tracking-[0.08em] text-unag-dark-green dark:border-white/20 dark:bg-white/5 dark:text-white/80">
                                                            {stage.badge}
                                                        </span>
                                                    )
                                                }
                                            </div>

                                            <p class="mt-1.5 text-sm leading-6 text-unag-gray/85 dark:text-white/75">
                                                {stage.description}
                                            </p>

                                            {
                                                stage.note && (
                                                    <p class="mt-1 text-sm italic text-unag-green dark:text-unag-light-green">
                                                        {stage.note}
                                                    </p>
                                                )
                                            }

                                            {
                                                stage.resources && (
                                                    <ul class="mt-3 flex flex-wrap gap-2">
                                                        {stage.resources.map((resource) => (
                                                            <li>
                                                                <a
                                                                    href={resource.href}
                                                                    class:list={[
                                                                        'inline-flex items-center gap-1.5 rounded-lg border px-2.5 py-1 text-xs font-semibold',
                                                                        resource.disabled
                                                                            ? 'cursor-not-allowed border-unag-light-gray bg-gray-100 text-unag-gray/65 dark:border-white/20 dark:bg-white/5 dark:text-white/55'
                                                                            : 'border-unag-green bg-unag-overlay-green text-unag-dark-green hover:bg-unag-green hover:text-white dark:border-white/20 dark:bg-unag-dark-green dark:text-white'
                                                                    ]}
                                                                    aria-disabled={resource.disabled ? 'true' : undefined}
                                                                    tabindex={resource.disabled ? '-1' : undefined}
                                                                >
                                                                    {resource.label}
                                                                    {
                                                                        resource.disabled && (
                                                                            <span class="text-[10px] font-medium normal-case">
                                                                                (pendiente)
                                                                            </span>
                                                                        )
                                                                    }
                                                                </a>
                                                            </li>
                                                        ))}
                                                    </ul>
                                                )
                                            }

                                            {
                                                stage.links && (
                                                    <div class="mt-3 flex flex-wrap gap-2">
                                                        {stage.links.map((link) => (
                                                            <a
                                                                href={link.href}
                                                                target={link.external ? '_blank' : undefined}
                                                                rel={link.external ? 'noopener noreferrer' : undefined}
                                                                class="inline-flex items-center gap-1 rounded-lg border border-unag-green bg-unag-overlay-green px-2.5 py-1 text-xs font-bold text-unag-dark-green transition-colors hover:bg-unag-green hover:text-white dark:border-white/20 dark:bg-unag-dark-green dark:text-white dark:hover:bg-unag-green"
                                                            >
                                                                {link.label}
                                                                <ArrowUpRight class="h-3.5 w-3.5" />
                                                            </a>
                                                        ))}
                                                    </div>
                                                )
                                            }
                                        </div>
                                    </div>
                                </article>
                            ))
                        }
                    </div>

                    <aside class="space-y-4">
                        <section class="rounded-lg border border-unag-light-gray bg-unag-dark-green p-4 text-sm dark:border-white/10 dark:bg-unag-dark-green">
                            <div class="flex items-start gap-2">
                                <BellRing class="mt-0.5 h-4 w-4 text-unag-green dark:text-unag-light-green" />
                                <h3 class="text-base font-bold text-white dark:text-white">
                                    05 Notificación de admisión
                                </h3>
                            </div>
                            <p class="mt-2 text-sm leading-6 text-white dark:text-white/80">
                                Si eres admitido, podrás descargar tu carta de admisión desde el portal oficial.
                            </p>
                            <a
                                href="https://portal.unag.edu.hn/matricula/aspirante/admision/formulario/resultado"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="mt-3 inline-flex items-center gap-1 rounded-lg border border-unag-green bg-white px-2.5 py-1 text-xs font-bold text-unag-dark-green transition-colors hover:bg-unag-green hover:text-white dark:border-white/20 dark:bg-white/10 dark:text-white"
                            >
                                Carta de admisión
                                <ArrowUpRight class="h-3.5 w-3.5" />
                            </a>
                        </section>

                        <section class="rounded-lg border border-unag-light-gray bg-white p-4 text-sm dark:border-white/10 dark:bg-background">
                            <p class="text-sm font-bold text-unag-dark-green dark:text-white">
                                Comunidad de aspirantes
                            </p>
                            <p class="mt-1 text-sm text-unag-gray/85 dark:text-white/75">
                                Únete al grupo oficial de Facebook para recibir avisos y resolver dudas frecuentes.
                            </p>
                            <a
                                href="https://www.facebook.com/groups/admisionesunag"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="mt-3 inline-flex items-center gap-1 rounded-lg border border-[#1a66d8] bg-[#1a66d8] px-2.5 py-1 text-xs font-bold text-white transition-colors hover:bg-[#1559bc]"
                            >
                                <Users class="h-3.5 w-3.5" />
                                Ir al grupo
                            </a>
                        </section>

                        <section class="rounded-lg border border-dashed border-unag-green/45 bg-white p-4 text-sm dark:border-white/20 dark:bg-background">
                            <p class="text-sm font-bold text-unag-dark-green dark:text-white">
                                Calendario oficial
                            </p>
                            <p class="mt-1 text-sm text-unag-gray/85 dark:text-white/75">
                                Consulta el cronograma completo con fechas clave del proceso de admisión.
                            </p>
                            <a
                                href="https://drive.google.com/file/d/1mP0fv3Kica_RE0J4EFdl3QFiDnMuuViK/view"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="mt-3 inline-flex items-center gap-1 rounded-lg border border-unag-green bg-unag-overlay-green px-2.5 py-1 text-xs font-bold text-unag-dark-green transition-colors hover:bg-unag-green hover:text-white dark:border-white/20 dark:bg-unag-dark-green dark:text-white"
                            >
                                <CalendarDays class="h-3.5 w-3.5" />
                                Descargar calendario
                                <Download class="h-3.5 w-3.5" />
                            </a>
                        </section>
                    </aside>
                </div>
            </div>
        </div>
    </section>
</Layout>   