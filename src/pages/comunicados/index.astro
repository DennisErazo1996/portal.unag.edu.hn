---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/main.astro';
import { MoveRight, Calendar, Tag, Star } from '@lucide/astro';

const comunicados = (await getCollection('comunicados')).sort(
  (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf()
);

const content = {
  title: "Comunicados | UNAG",
};

const categoryColors: Record<string, string> = {
  'Convocatoria': 'bg-unag-green',
  'Evento': 'bg-unag-dark-green',
  'Aviso': 'bg-unag-light-green',
  'Graduación': 'bg-unag-green',
  'Becas': 'bg-unag-light-green',
  'Académico': 'bg-unag-dark-green',
};
---

<Layout content={content}>
  <!-- Hero Header -->
  <div class="relative h-[60vh] w-full overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="https://images.pexels.com/photos/96715/pexels-photo-96715.jpeg" 
        alt="Comunicados UNAG"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/80"></div>
    </div>

    <div class="relative h-full flex flex-col justify-center items-center text-center px-6">
      <!-- <p class="flex gap-2 text-white/90 items-center mb-4">
        <MoveRight size={20} /> Noticias y Anuncios
      </p> -->
      <h1 class="font-extrabold text-white text-5xl lg:text-7xl leading-none mb-2">
        Comunicados
      </h1>
      <p class="text-white/90 text-lg max-w-3xl">
        Mantente informado sobre las últimas noticias, eventos y comunicados oficiales de la Universidad Nacional de Agricultura.
      </p>
    </div>
  </div>

  <!-- Comunicados Grid -->
  <section class="py-16 px-6 lg:px-20 bg-gradient-to-b from-gray-50 to-white">
    <div class="max-w-7xl mx-auto">
      
      <!-- Filtros -->
      <div class="mb-8 flex flex-col md:flex-row gap-4">
        <!-- Búsqueda por nombre -->
        <div class="flex-1">
          <input 
            type="text" 
            id="search-input"
            placeholder="Buscar comunicado por nombre..."
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-unag-green focus:ring-2 focus:ring-unag-green/20 outline-none transition-all"
          />
        </div>
        
        <!-- Filtro por categoría -->
        <div class="md:w-64">
          <select 
            id="category-filter"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-unag-green focus:ring-2 focus:ring-unag-green/20 outline-none transition-all bg-white"
          >
            <option value="">Todas las categorías</option>
            <option value="Convocatoria">Convocatoria</option>
            <option value="Evento">Evento</option>
            <option value="Aviso">Aviso</option>
            <option value="Graduación">Graduación</option>
            <option value="Becas">Becas</option>
            <option value="Académico">Académico</option>
          </select>
        </div>
      </div>

      <!-- Grid de comunicados -->
      <div id="comunicados-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          comunicados.map((comunicado : any) => (
            <article 
              class="comunicado-card group bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 border border-gray-100"
              data-title={comunicado.data.title.toLowerCase()}
              data-category={comunicado.data.category}
            >
              <div class="h-40 bg-[url('https://images.pexels.com/photos/1002703/pexels-photo-1002703.jpeg')] bg-cover bg-center relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-unag-green/20 to-unag-dark-green/40" />
                <div class="absolute top-3 left-3">
                  <span class={`px-2.5 py-1 rounded-full text-white text-xs font-bold ${categoryColors[comunicado.data.category]} shadow-lg`}>
                    <Tag size={12} class="inline mr-1" />
                    {comunicado.data.category}
                  </span>
                </div>
                {comunicado.data.featured && (
                  <div class="absolute top-3 right-3">
                    <span class="px-2.5 py-1 flex items-center gap-2 rounded-full bg-unag-yellow text-unag-dark-green text-xs font-bold shadow-lg">
                      <Star size={12} /> Destacado
                    </span>
                  </div>
                )}
              </div>
              
              <div class="p-5">
                <div class="flex items-center gap-2 text-xs text-gray-500 mb-3">
                  <Calendar size={14} />
                  <time>
                    {new Date(comunicado.data.date).toLocaleDateString('es-HN', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </time>
                </div>
                
                <h2 class="text-lg font-bold text-unag-dark-green group-hover:text-unag-green transition-colors line-clamp-2 mb-2">
                  {comunicado.data.title}
                </h2>
                
                <p class="text-sm text-gray-600 line-clamp-2 mb-4">
                  {comunicado.data.description}
                </p>
                
                <a 
                  href={`/comunicados/${comunicado.slug}`}
                  class="inline-flex items-center gap-2 text-sm text-unag-green font-semibold hover:gap-3 transition-all duration-300"
                >
                  Leer más
                  <MoveRight size={16} />
                </a>
              </div>
            </article>
          ))
        }
      </div>

      
      <div id="no-results" class="hidden text-center py-12">
        <div class="inline-block p-8 bg-white rounded-2xl shadow-lg">
          <div class="text-6xl mb-4">🔍</div>
          <h3 class="text-2xl font-bold text-unag-dark-green mb-2">No se encontraron comunicados</h3>
          <p class="text-gray-600">Intenta con otros términos de búsqueda o categoría</p>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
  const comunicadosGrid = document.getElementById('comunicados-grid') as HTMLElement;
  const noResults = document.getElementById('no-results') as HTMLElement;
  const comunicadoCards = document.querySelectorAll('.comunicado-card') as NodeListOf<HTMLElement>;

  function filterComunicados() {
    const searchTerm = searchInput.value.toLowerCase();
    const selectedCategory = categoryFilter.value;
    let visibleCount = 0;

    comunicadoCards.forEach(card => {
      const title = card.dataset.title || '';
      const category = card.dataset.category || '';

      const matchesSearch = title.includes(searchTerm);
      const matchesCategory = selectedCategory === '' || category === selectedCategory;

      if (matchesSearch && matchesCategory) {
        card.style.display = 'block';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

  
    if (visibleCount === 0) {
      noResults.classList.remove('hidden');
      comunicadosGrid.classList.add('hidden');
    } else {
      noResults.classList.add('hidden');
      comunicadosGrid.classList.remove('hidden');
    }
  }

  
  searchInput.addEventListener('input', filterComunicados);
  categoryFilter.addEventListener('change', filterComunicados);
</script>
