---
import Layout from "../layouts/main.astro";
import Hero from "@/components/astro/hero.astro";
import CarrerasSection from "@/components/react/CarrerasSection";
import ComunicadosSection from "@/components/react/ComunicadosSection";
import NoticiasSection from "@/components/react/NoticiasSection";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import imgEstudio from "@assets/img/estudio.png";
import imgTrabajo from "@assets/img/trabajo.png";
import imgDisciplina from "@assets/img/disciplina.png";

const content = {
	title: "UNAG | Universidad Nacional de Agricultura",
};

const comunicados = (await getCollection("comunicados")).sort(
	(a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const añoFundacion = 1952;
const añoActual = new Date().getFullYear();
const añosDesdesFundacion = añoActual - añoFundacion;
---

<Layout content={content}>
	<Hero />

	<ComunicadosSection client:load comunicados={comunicados} />

	<NoticiasSection client:load />

	<CarrerasSection client:load />

	<section
		id="lema-section"
		class="relative text-[12px] w-full h-[100vh] flex items-center justify-center overflow-hidden"
	>
		<!-- Círculo central con animación flotante -->
		<div
			class="pointer-events-none w-100 h-100 lg:w-200 lg:h-200 bg-unag-overlay-green rounded-full animate-float"
		>
		</div>
		
		<!-- Círculo izquierdo con animación flotante inversa -->
		<div
			class="absolute pointer-events-none left-0 -translate-x-20 w-100 h-100 lg:w-200 lg:h-200 rounded-full bg-transparent border border-unag-dark-green animate-float-reverse"
		>
		</div>
		
		<!-- Círculo derecho con animación flotante -->
		<div
			class="absolute pointer-events-none right-0 translate-x-20 w-100 h-100 lg:w-200 lg:h-200 rounded-full bg-transparent border border-unag-dark-green animate-float"
		>
		</div>
		
		<div class="absolute -translate-y-80">
			<p
				class="text-[80px] lg:text-[150px] lg:-translate-x-5 pointer-events-none select-none font-black text-unag-dark-green italic top-0 leading-none"
			>
				{añosDesdesFundacion}
			</p>
			<p
				class="absolute pointer-events-none select-none translate-x-20 lg:translate-x-35 translate-y-10 text-[50px] lg:text-[110px] leading-none texto-lema text-unag-light-green top-0"
			>
				años
			</p>
			<p class="text-[20px] font-normal pointer-events-none select-none">
				¡Formando líderes!
			</p>
		</div>
		
		<div class="absolute flex items-center gap-5 lg:gap-15 scale-90 lg:scale-120 mt-0 lg:mt-20">
			<div class="flex flex-col items-center gap-2 group">
				<p class="bg-unag-green text-white p-2 rounded-full w-fit px-5">
					Estudio
				</p>
				<Image 
					src={imgEstudio} 
					alt="Estudio" 
					class="w-50 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6" 
				/>
			</div>
			<div class="flex flex-col items-center gap-2 group">
				<Image 
					src={imgTrabajo} 
					alt="Trabajo" 
					class="w-50 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-6" 
				/>
				<p class="bg-unag-green text-white p-2 rounded-full w-fit px-5">
					Trabajo
				</p>
			</div>
			<div class="flex flex-col items-center gap-2 group">
				<p class="bg-unag-green text-white p-2 rounded-full w-fit px-5">
					Disciplina
				</p>
				<Image 
					src={imgDisciplina} 
					alt="Disciplina" 
					class="w-50 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6" 
				/>
			</div>
		</div>
	</section>

	<section class="relative w-full min-h-screen lg:py-20 bg-white">
		<div class="max-w-[1400px] mx-auto px-4 lg:px-8">
			<!-- Encabezado -->
			<div class="flex flex-col text-center mb-12">
				<p class="text-sm text-gray-600">Oferta académica</p>
				<h2 class="text-3xl md:text-4xl font-extrabold text-green-900 mb-6">
					NUESTROS POSGRADOS
				</h2>
			</div>

			<!-- Grid de Posgrados -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-[200px]">
				
				<!-- Doctorado en Ciencias Agrarias - Grande (3 columnas en desktop) -->
				<div class="relative lg:col-span-3 md:col-span-2 lg:row-span-2 rounded-2xl overflow-hidden group">
					<div class="absolute inset-0 bg-[url('https://images.pexels.com/photos/2280571/pexels-photo-2280571.jpeg')] bg-cover bg-center transition-transform duration-500 group-hover:scale-110"></div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
					<div class="relative h-full flex flex-col justify-end p-6 text-white">
						<p class="bg-unag-green rounded-full w-fit px-4 py-1 text-sm mb-2">Doctorado en</p>
						<p class="font-black text-2xl md:text-3xl mb-4 uppercase">CIENCIAS AGRARIAS</p>
						<a href="" class="bg-unag-dark-green hover:bg-unag-green text-white w-fit px-4 py-2 rounded-lg text-sm transition-colors flex items-center gap-2">
							Más información
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</a>
					</div>
				</div>

				<!-- Maestría en Producción Animal -->
				<div class="relative md:col-span-1 lg:col-span-2 rounded-2xl overflow-hidden group">
					<div class="absolute inset-0 bg-[url('https://images.pexels.com/photos/1374295/pexels-photo-1374295.jpeg')] bg-cover bg-center transition-transform duration-500 group-hover:scale-110"></div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
					<div class="relative h-full flex flex-col justify-end p-6 text-white">
						<p class="bg-unag-green rounded-full w-fit px-4 py-1 text-sm mb-2">Maestría en</p>
						<p class="font-black text-xl md:text-2xl mb-3 uppercase">Recursos Naturales y Producción Sostenible</p>
						<a href="" class="bg-unag-dark-green hover:bg-unag-green text-white w-fit px-4 py-2 rounded-lg text-sm transition-colors flex items-center gap-2">
							Ver más
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</a>
					</div>
				</div>

				<!-- Maestría en Gestión Ambiental -->
				<div class="relative md:col-span-1 rounded-2xl overflow-hidden group">
					<div class="absolute inset-0 bg-[url('https://images.pexels.com/photos/65175/pexels-photo-65175.jpeg')] bg-cover bg-center transition-transform duration-500 group-hover:scale-110"></div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
					<div class="relative h-full flex flex-col justify-end p-6 text-white">
						<p class="bg-unag-green rounded-full w-fit px-4 py-1 text-xs mb-2">Maestría en</p>
						<p class="font-black text-lg mb-3 uppercase">Ciencias Agroalimentarias</p>
						<a href="" class="bg-unag-dark-green hover:bg-unag-green text-white w-fit px-3 py-2 rounded-lg text-xs transition-colors flex items-center gap-2">
							Ver más
							<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</a>
					</div>
				</div>

				<!-- Maestría en Desarrollo Rural -->
				<div class="relative md:col-span-1 rounded-2xl overflow-hidden group">
					<div class="absolute inset-0 bg-[url('https://images.pexels.com/photos/1459495/pexels-photo-1459495.jpeg')] bg-cover bg-center transition-transform duration-500 group-hover:scale-110"></div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
					<div class="relative h-full flex flex-col justify-end p-6 text-white">
						<p class="bg-unag-green rounded-full w-fit px-4 py-1 text-xs mb-2">Maestría en</p>
						<p class="font-black text-lg mb-3 uppercase">Recursos Naturales y Producción Sostenible</p>
						<a href="" class="bg-unag-dark-green hover:bg-unag-green text-white w-fit px-3 py-2 rounded-lg text-xs transition-colors flex items-center gap-2">
							Ver más
							<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</a>
					</div>
				</div>

				<!-- Maestría en Agronegocios -->
				<div class="relative md:col-span-2 lg:col-span-2 rounded-2xl overflow-hidden group">
					<div class="absolute inset-0 bg-[url('https://images.pexels.com/photos/1459495/pexels-photo-1459495.jpeg')] bg-cover bg-center transition-transform duration-500 group-hover:scale-110"></div>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
					<div class="relative h-full flex flex-col justify-end p-6 text-white">
						<p class="bg-unag-green rounded-full w-fit px-4 py-1 text-sm mb-2">Maestría en</p>
						<p class="font-black text-xl md:text-2xl mb-3 uppercase">Biotecnología Agroalimentaria</p>
						<a href="" class="bg-unag-dark-green hover:bg-unag-green text-white w-fit px-4 py-2 rounded-lg text-sm transition-colors flex items-center gap-2">
							Ver más
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
							</svg>
						</a>
					</div>
				</div>

			</div>
		</div>
	</section>
</Layout>


<style>
	@keyframes float {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(-20px);
		}
	}

	@keyframes float-reverse {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(20px);
		}
	}

	.animate-float {
		animation: float 6s ease-in-out infinite;
	}

	.animate-float-reverse {
		animation: float-reverse 6s ease-in-out infinite;
	}
</style>
