---
import Layout from '../layouts/main.astro';
import Hero from '@/components/astro/hero.astro'
import CarrerasSection from '@/components/react/CarrerasSection';
import ComunicadosSection from '@/components/react/ComunicadosSection';
import { getCollection } from 'astro:content';

const content = {
	title: "UNAG | Universidad Nacional de Agricultura"
}

const comunicados = (await getCollection('comunicados'))
	.sort((a : any, b : any) => b.data.date.valueOf() - a.data.date.valueOf());

---

<Layout content={content}>
	<Hero />

	<ComunicadosSection client:load comunicados={comunicados} />

	<CarrerasSection client:load/>
</Layout>
