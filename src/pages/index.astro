---
import Layout from '../layouts/main.astro';
import Hero from '@/components/astro/hero.astro'
import { getCollection } from 'astro:content';

import {MoveRight, ArrowUpRight} from '@lucide/astro';

const content = {
	title: "UNAG | Universidad Nacional de Agricultura"
}


const comunicados = (await getCollection('comunicados'))
	.sort((a : any, b : any) => b.data.date.valueOf() - a.data.date.valueOf());

console.log('Total comunicados:', comunicados.length); 

const categoryColors: Record<string, string> = {
	'Convocatoria': 'bg-unag-light-green',
	'Evento': 'bg-unag-light-green',
	'Aviso': 'bg-unag-light-green',
	'Graduación': 'bg-unag-light-green',
	'Becas': 'bg-unag-light-green',
	'Académico': 'bg-unag-light-green',
};

---

<Layout content={content}>
	<Hero />

	<section id="comunicados" class="relative flex justify-center items-center w-full min-h-screen text-unag-gray py-20">
		<div class="absolute z-5 w-[90%] lg:w-[80%] mx-auto -translate-y-20">
			<header class="">
				<p class="flex gap-2"><MoveRight /> Últimas Publicaciones</p>
				<h1 class="font-extrabold text-unag-dark-green text-3xl md:text-5xl lg:text-[60px] leading-none">Comunicados</h1>
			</header>
			<div class="mt-20">
				<!-- Swiper Container -->
				<div class="relative overflow-hidden px-2">
					<div id="comunicados-swiper" class="flex gap-4 md:gap-6 transition-transform duration-500 ease-out">
						{comunicados.map((comunicado: any) => (
							<div class="comunicado-card w-[85vw] sm:w-[45vw] md:w-[30vw] lg:w-70 flex-shrink-0">
								<div class="relative z-5 bg-unag-dark-green w-full h-70 rounded-3xl before:content-[''] before:absolute before:-top-1
								 before:left-1/2 before:-translate-x-1/2 before:w-1/2 before:h-2 before:bg-unag-green before:rounded-full">

								 <div class="flex flex-col gap-2 pt-8 px-5">
									<p class={`relative px-3 w-fit text-unag-dark-green font-extrabold rounded-full text-[12px] ${categoryColors[comunicado.data.category]}`}>
										{comunicado.data.category}
									</p>
									<p class="text-white font-extrabold text-[14px] line-clamp-3">
										{comunicado.data.title}
									</p>
								 </div>

								 <div class="flex justify-between items-center absolute bottom-5 px-5 w-full">
									<div>
										<p class="text-white text-[12px] italic">
											{new Date(comunicado.data.date).toLocaleDateString('es-HN', {
												year: 'numeric',
												month: 'long',
												day: 'numeric'
											})}
										</p>
									</div>
									<div class="bg-unag-green p-3 rounded-full hover:scale-110 transition-transform duration-400 cursor-pointer">
										<a href={`/comunicados/${comunicado.slug}`} class="text-white font-extrabold rounded-full"><ArrowUpRight /></a>
									</div>
								 </div>
								</div>
							</div>
						))}
					</div>
				</div>

				<!-- Pagination Dots & Ver Todos Button -->
				<div class="flex justify-between items-center mt-8">
					<div id="swiper-dots" class="flex gap-3">
						<button class="dot active w-10 h-2 rounded-full bg-unag-green transition-all duration-300" data-index="0"></button>
						<button class="dot w-2 h-2 rounded-full bg-unag-gray transition-all duration-300" data-index="1"></button>
						<button class="dot w-2 h-2 rounded-full bg-unag-gray transition-all duration-300" data-index="2"></button>
					</div>
					<a href="/comunicados" class="flex items-center gap-2 text-unag-dark-green font-bold hover:text-unag-green transition-colors duration-300 group">
						Ver todos los comunicados 
						<MoveRight class="group-hover:translate-x-2 transition-transform duration-300" />
					</a>
				</div>
			</div>
		</div>
		<div class="absolute w-full h-[50%] bottom-0 bg-unag-light-gray"></div>
	</section>
</Layout>

<script>
	const swiper = document.getElementById('comunicados-swiper');
	const dots = document.querySelectorAll('.dot');
	const cards = document.querySelectorAll('.comunicado-card');
	let currentIndex = 0;
	
	// Determinar cards por página según tamaño de pantalla
	function getCardsPerPage() {
		const width = window.innerWidth;
		if (width < 640) return 1; // Mobile
		if (width < 768) return 2; // Tablet pequeña
		if (width < 1024) return 2; // Tablet
		return 3; // Desktop
	}
	
	let cardsPerPage = getCardsPerPage();
	let totalPages = Math.ceil(cards.length / cardsPerPage);

	function updateSwiper() {
		const card = cards[0] as HTMLElement;
		if (!card) return;
		
		const cardWidth = card.offsetWidth;
		const gap = window.innerWidth < 768 ? 16 : 24; // gap-4 o gap-6
		const offset = currentIndex * cardsPerPage * (cardWidth + gap);
		
		if (swiper) {
			swiper.style.transform = `translateX(-${offset}px)`;
		}

		// Update dots
		dots.forEach((dot, index) => {
			if (index === currentIndex) {
				dot.classList.add('active', 'w-10', 'bg-unag-green');
				dot.classList.remove('w-2', 'bg-unag-gray');
			} else {
				dot.classList.remove('active', 'w-10', 'bg-unag-green');
				dot.classList.add('w-2', 'bg-unag-gray');
			}
		});
	}
	
	// Recalcular al cambiar tamaño de ventana
	window.addEventListener('resize', () => {
		const newCardsPerPage = getCardsPerPage();
		if (newCardsPerPage !== cardsPerPage) {
			cardsPerPage = newCardsPerPage;
			totalPages = Math.ceil(cards.length / cardsPerPage);
			currentIndex = Math.min(currentIndex, totalPages - 1);
			updateSwiper();
		}
	});

	dots.forEach((dot) => {
		dot.addEventListener('click', () => {
			const index = parseInt(dot.getAttribute('data-index') || '0');
			if (index < totalPages) {
				currentIndex = index;
				updateSwiper();
			}
		});
	});

	// setInterval(() => {
	// 	currentIndex = (currentIndex + 1) % totalPages;
	// 	updateSwiper();
	// }, 5000);

	
	let startX = 0;
	let isDragging = false;

	swiper?.addEventListener('mousedown', (e) => {
		isDragging = true;
		startX = e.pageX;
	});

	swiper?.addEventListener('mousemove', (e) => {
		if (!isDragging) return;
		e.preventDefault();
	});

	swiper?.addEventListener('mouseup', (e) => {
		if (!isDragging) return;
		isDragging = false;
		const diff = startX - e.pageX;
		
		if (Math.abs(diff) > 50) {
			if (diff > 0 && currentIndex < totalPages - 1) {
				currentIndex++;
			} else if (diff < 0 && currentIndex > 0) {
				currentIndex--;
			}
			updateSwiper();
		}
	});

	
	swiper?.addEventListener('touchstart', (e) => {
		startX = e.touches[0].pageX;
	});

	swiper?.addEventListener('touchend', (e) => {
		const diff = startX - e.changedTouches[0].pageX;
		
		if (Math.abs(diff) > 50) {
			if (diff > 0 && currentIndex < totalPages - 1) {
				currentIndex++;
			} else if (diff < 0 && currentIndex > 0) {
				currentIndex--;
			}
			updateSwiper();
		}
	});
</script>
