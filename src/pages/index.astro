---
import Layout from "../layouts/main.astro";
import Hero from "@/components/astro/hero.astro";
import CarrerasSection from "@/components/react/CarrerasSection";
import ComunicadosSection from "@/components/react/ComunicadosSection";
import NoticiasSection from "@/components/react/NoticiasSection";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import imgEstudio from "@assets/img/estudio.png";
import imgTrabajo from "@assets/img/trabajo.png";
import imgDisciplina from "@assets/img/disciplina.png";
import { Star } from "@lucide/astro";

const content = {
	title: "UNAG | Universidad Nacional de Agricultura",
};

const comunicados = (await getCollection("comunicados")).sort(
	(a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const añoFundacion = 1952;
const añoActual = new Date().getFullYear();
const añosDesdesFundacion = añoActual - añoFundacion;
---

<Layout content={content}>
	<Hero />

	<ComunicadosSection client:load comunicados={comunicados} />

	<NoticiasSection client:load />

	<CarrerasSection client:load />

	<section
		id="lema-section"
		class="relative text-[12px] w-full h-[100vh] flex items-center justify-center overflow-hidden"
	>
		<!-- Círculo central con animación flotante -->
		<div
			class="pointer-events-none w-100 h-100 lg:w-200 lg:h-200 bg-unag-overlay-green rounded-full animate-float"
		>
		</div>
		
		<!-- Círculo izquierdo con animación flotante inversa -->
		<div
			class="absolute pointer-events-none left-0 -translate-x-20 w-100 h-100 lg:w-200 lg:h-200 rounded-full bg-transparent border border-unag-dark-green animate-float-reverse"
		>
		</div>
		
		<!-- Círculo derecho con animación flotante -->
		<div
			class="absolute pointer-events-none right-0 translate-x-20 w-100 h-100 lg:w-200 lg:h-200 rounded-full bg-transparent border border-unag-dark-green animate-float"
		>
		</div>
		
		<div class="absolute -translate-y-80">
			<p
				class="text-[80px] lg:text-[150px] lg:-translate-x-5 pointer-events-none select-none font-black text-unag-dark-green italic top-0 leading-none"
			>
				{añosDesdesFundacion}
			</p>
			<p
				class="absolute pointer-events-none select-none translate-x-20 lg:translate-x-35 translate-y-10 text-[50px] lg:text-[110px] leading-none texto-lema text-unag-light-green top-0"
			>
				años
			</p>
			<p class="text-[20px] font-normal pointer-events-none select-none">
				¡Formando líderes!
			</p>
		</div>
		
		<div class="absolute flex items-center gap-5 lg:gap-15 scale-90 lg:scale-120 mt-0 lg:mt-20">
			<div class="flex flex-col items-center gap-2 group">
				<p class="bg-unag-green text-white p-2 rounded-full w-fit px-5">
					Estudio
				</p>
				<Image 
					src={imgEstudio} 
					alt="Estudio" 
					class="w-50 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6" 
				/>
			</div>
			<div class="flex flex-col items-center gap-2 group">
				<Image 
					src={imgTrabajo} 
					alt="Trabajo" 
					class="w-50 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-6" 
				/>
				<p class="bg-unag-green text-white p-2 rounded-full w-fit px-5">
					Trabajo
				</p>
			</div>
			<div class="flex flex-col items-center gap-2 group">
				<p class="bg-unag-green text-white p-2 rounded-full w-fit px-5">
					Disciplina
				</p>
				<Image 
					src={imgDisciplina} 
					alt="Disciplina" 
					class="w-50 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6" 
				/>
			</div>
		</div>
	</section>

	<section class="relative w-full py-16 lg:py-24 bg-gradient-to-br from-gray-50 via-white to-unag-overlay-green/20 overflow-hidden">
		<!-- Decoración de fondo -->
		<div class="absolute inset-0 opacity-5">
			<div class="absolute top-10 right-10 w-72 h-72 bg-unag-green rounded-full blur-3xl"></div>
			<div class="absolute bottom-20 left-10 w-96 h-96 bg-unag-light-green rounded-full blur-3xl"></div>
		</div>

		<div class="relative max-w-[1400px] mx-auto px-4 lg:px-8">
			<!-- Encabezado mejorado -->
			<div class="flex flex-col items-center text-center mb-16">
				<div class="inline-flex items-center gap-2 bg-unag-green/10 backdrop-blur-sm px-4 py-2 rounded-full mb-4">
					<div class="w-2 h-2 bg-unag-green rounded-full animate-pulse"></div>
					<p class="text-sm font-semibold text-unag-dark-green">Oferta Académica de Posgrado</p>
				</div>
				<h2 class="text-4xl md:text-5xl lg:text-5xl font-black text-unag-dark-green mb-4 leading-none">
					NUESTROS POSGRADOS
				</h2>
				<p class="text-gray-600 max-w-2xl text-sm">
					Programas de excelencia académica para profesionales que buscan especializarse y liderar en el sector agrícola
				</p>
			</div>

			<!-- Grid renovado de Posgrados -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 mb-12">
				
				<!-- Doctorado en Ciencias Agrarias - Destacado -->
				<div class="lg:col-span-8 md:col-span-2 relative group">
					<div class="relative h-[500px] rounded-3xl overflow-hidden shadow-2xl">
						<div class="absolute inset-0 bg-gradient-to-br from-unag-dark-green/30 to-black/60 z-5"></div>
						<img 
							src="https://images.pexels.com/photos/2280571/pexels-photo-2280571.jpeg" 
							alt="Doctorado en Ciencias Agrarias"
							class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
						/>
						<div class="absolute inset-0 z-5 flex flex-col justify-between p-5">
							<div class="flex items-start justify-between">
								<!-- <span class="flex justify-center items-center gap-2 bg-yellow-400 text-unag-dark-green font-bold px-4 py-2 rounded-full text-sm tracking-wide shadow-lg">
								<Star/>	 Programa Destacado
								</span> -->
							</div>
							<div>
								<div class="inline-block bg-white/20 backdrop-blur-md px-4 py-2 rounded-lg mb-3">
									<p class="text-white/90 text-sm font-semibold">Doctorado en</p>
								</div>
								<h3 class="text-4xl lg:text-5xl font-black text-white mb-4 leading-none">
									CIENCIAS AGRARIAS
								</h3>
								<p class="text-white/90 mb-6 max-w-xl text-md">
									El programa doctoral más completo de la región, formando investigadores de alto nivel
								</p>
								<div class="flex flex-wrap gap-3">
									<a href="#" class="group/btn bg-white hover:bg-unag-green text-unag-dark-green hover:text-white font-bold px-6 py-3 rounded-xl transition-all flex items-center gap-2 shadow-lg hover:shadow-xl hover:-translate-y-1">
										Más información
										<svg class="w-5 h-5 transition-transform group-hover/btn:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
										</svg>
									</a>
									<button class="bg-white/20 backdrop-blur-md hover:bg-white/30 text-white font-semibold px-6 py-3 rounded-xl transition-all border border-white/30">
										Descargar Plan
									</button>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Maestrías - Columna derecha -->
				<div class="lg:col-span-4 md:col-span-2 space-y-6">
					<!-- Maestría 1 -->
					<div class="relative group h-[240px]">
						<div class="relative h-full rounded-2xl overflow-hidden shadow-lg">
							<div class="absolute inset-0 bg-gradient-to-t from-black/80 to-black/20 z-5"></div>
							<img 
								src="https://images.pexels.com/photos/1374295/pexels-photo-1374295.jpeg" 
								alt="Maestría"
								class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
							/>
							<div class="absolute inset-0 z-5 flex flex-col justify-end p-6">
								<span class="inline-block bg-unag-green rounded-full px-3 py-1 text-xs font-semibold text-white mb-2 w-fit">
									Maestría
								</span>
								<h4 class="text-xl font-black text-white mb-3 leading-tight">
									RECURSOS NATURALES Y PRODUCCIÓN SOSTENIBLE
								</h4>
								<a href="#" class="text-white hover:text-unag-light-green transition-colors text-sm font-medium flex items-center gap-2 group/link">
									Conocer más
									<svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
									</svg>
								</a>
							</div>
						</div>
					</div>

					<!-- Maestría 2 -->
					<div class="relative group h-[240px]">
						<div class="relative h-full rounded-2xl overflow-hidden shadow-lg">
							<div class="absolute inset-0 bg-gradient-to-t from-black/80 to-black/20 z-5"></div>
							<img 
								src="https://images.pexels.com/photos/65175/pexels-photo-65175.jpeg" 
								alt="Maestría"
								class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
							/>
							<div class="absolute inset-0 z-5 flex flex-col justify-end p-6">
								<span class="inline-block bg-unag-green rounded-full px-3 py-1 text-xs font-semibold text-white mb-2 w-fit">
									Maestría
								</span>
								<h4 class="text-xl font-black text-white mb-3 leading-tight">
									CIENCIAS AGROALIMENTARIAS
								</h4>
								<a href="#" class="text-white hover:text-unag-light-green transition-colors text-sm font-medium flex items-center gap-2 group/link">
									Conocer más
									<svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
									</svg>
								</a>
							</div>
						</div>
					</div>
				</div>

				<!-- Fila inferior - 3 maestrías -->
				<div class="lg:col-span-4 md:col-span-1 relative group">
					<div class="relative h-[280px] rounded-2xl overflow-hidden shadow-lg">
						<div class="absolute inset-0 bg-gradient-to-t from-black/80 to-black/20 z-5"></div>
						<img 
							src="https://images.pexels.com/photos/1459495/pexels-photo-1459495.jpeg" 
							alt="Maestría"
							class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
						/>
						<div class="absolute inset-0 z-5 flex flex-col justify-end p-6">
							<span class="inline-block bg-unag-green rounded-full px-3 py-1 text-xs font-semibold text-white mb-2 w-fit">
								Maestría
							</span>
							<h4 class="text-2xl font-black text-white mb-3 leading-tight">
								DESARROLLO RURAL SOSTENIBLE
							</h4>
							<a href="#" class="text-white hover:text-unag-light-green transition-colors text-sm font-medium flex items-center gap-2 group/link">
								Conocer más
								<svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
								</svg>
							</a>
						</div>
					</div>
				</div>

				<div class="lg:col-span-4 md:col-span-1 relative group">
					<div class="relative h-[280px] rounded-2xl overflow-hidden shadow-lg">
						<div class="absolute inset-0 bg-gradient-to-t from-black/80 to-black/20 z-5"></div>
						<img 
							src="https://images.pexels.com/photos/2280571/pexels-photo-2280571.jpeg" 
							alt="Maestría"
							class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
						/>
						<div class="absolute inset-0 z-5 flex flex-col justify-end p-6">
							<span class="inline-block bg-unag-green rounded-full px-3 py-1 text-xs font-semibold text-white mb-2 w-fit">
								Maestría
							</span>
							<h4 class="text-2xl font-black text-white mb-3 leading-tight">
								BIOTECNOLOGÍA AGROALIMENTARIA
							</h4>
							<a href="#" class="text-white hover:text-unag-light-green transition-colors text-sm font-medium flex items-center gap-2 group/link">
								Conocer más
								<svg class="w-4 h-4 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
								</svg>
							</a>
						</div>
					</div>
				</div>

				<div class="lg:col-span-4 md:col-span-2 relative group">
					<div class="relative h-[280px] rounded-2xl overflow-hidden shadow-lg bg-unag-dark-green flex items-center justify-center">
						
						<div class="absolute inset-0 opacity-5">
							<svg class="w-full h-full" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
								<pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
									<circle cx="5" cy="5" r="1" fill="white"/>
								</pattern>
								<rect width="100" height="100" fill="url(#grid)"/>
							</svg>
						</div>
						
						<div class="relative text-center p-8 space-y-4">
							<div class="flex justify-center mb-4">
								<div class="bg-unag-green/20 p-4 rounded-2xl">
									<svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
									</svg>
								</div>
							</div>
							<h4 class="text-2xl lg:text-3xl font-black text-white leading-none uppercase">
								Matricúlate en la UNAG
							</h4>
							<p class="text-xl text-unag-light-green font-bold leading-none">
								Y Crece
							</p>
						</div>
					</div>
				</div>

			</div>

			<!-- CTA al final -->
			<!-- <div class="bg-gradient-to-r from-unag-dark-green via-unag-green to-unag-dark-green rounded-3xl p-8 lg:p-12 text-center shadow-2xl relative overflow-hidden">
				<div class="absolute inset-0 opacity-10">
					<div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full blur-3xl"></div>
					<div class="absolute bottom-0 left-0 w-96 h-96 bg-white rounded-full blur-3xl"></div>
				</div>
				<div class="relative z-5">
					<h3 class="text-3xl lg:text-4xl font-black text-white mb-4">
						¿Listo para llevar tu carrera al siguiente nivel?
					</h3>
					<p class="text-white/90 text-lg mb-8 max-w-2xl mx-auto">
						Descubre todos nuestros programas de posgrado y encuentra el que mejor se adapta a tus objetivos profesionales
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href="#" class="bg-white hover:bg-gray-100 text-unag-dark-green font-bold px-8 py-4 rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-1 flex items-center justify-center gap-2">
							Ver todos los posgrados
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
							</svg>
						</a>
						<a href="#" class="bg-transparent border-2 border-white hover:bg-white hover:text-unag-dark-green text-white font-bold px-8 py-4 rounded-xl transition-all">
							Solicitar información
						</a>
					</div>
				</div>
			</div> -->
		</div>
	</section>
</Layout>


<style>
	@keyframes float {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(-20px);
		}
	}

	@keyframes float-reverse {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(20px);
		}
	}

	.animate-float {
		animation: float 6s ease-in-out infinite;
	}

	.animate-float-reverse {
		animation: float-reverse 6s ease-in-out infinite;
	}
</style>
