---
export const prerender = true;

import Layout from "@/layouts/main.astro";
import HeaderPages from "@/components/astro/ui/header-bg-pages.astro";
import { Quote, Mail, Phone } from "lucide-react";

const content = {
  title: "Rector | UNAG",
};

const rectorInfo = {
  name: "Ph. D. Roy Donald Menjivar",
  title: "Rector de la Universidad Nacional de Agricultura",
  email: "rectoria@unag.edu.hn",
  image: "/img/rector-roy.jpg",
};
---

<Layout content={content}>
  <HeaderPages
    imagen="/img/bg-default-unag-02.webp"
    etiqueta="Organización"
    subetiqueta="Rectoría"
    titulo="Rector"
    descripcion="Conozca al Rector de la Universidad Nacional de Agricultura, su trayectoria académica y su visión para el futuro de la institución."
  />

  <section
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 -mt-30 relative z-2"
  >
    <div
      class="bg-white rounded-2xl shadow-xl overflow-hidden dark:border-unag-green dark:border"
    >
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-0">
        <!-- Sidebar / Photo Section -->
        <div
          class="lg:col-span-4 bg-gray-50 p-8 flex flex-col items-center text-center border-r border-gray-100 dark:bg-background dark:border-unag-green"
        >
          <div
            class="relative w-64 h-80 rounded-xl overflow-hidden shadow-lg mb-6 group bg-white"
          >
            <div
              class="absolute inset-0 bg-unag-green/10 group-hover:bg-transparent transition-colors duration-300 pointer-events-none"
            >
            </div>
            <img
              src={rectorInfo.image}
              alt={rectorInfo.name}
              class="w-full h-full object-cover"
            />
          </div>

          <h2
            class="text-2xl font-bold text-unag-dark-green dark:text-white mb-2"
          >
            {rectorInfo.name}
          </h2>
          <p class="text-unag-green font-medium mb-6 text-sm leading-tight">
            {rectorInfo.title}
          </p>

          <div
            class="w-full space-y-4 text-left p-4 bg-white dark:bg-unag-dark-green rounded-lg border border-gray-100 dark:border-unag-green shadow-sm"
          >
            <div class="flex items-center gap-3 text-gray-600 dark:text-white">
              <Mail className="w-5 h-5 text-unag-green" />
              <a
                href={`mailto:${rectorInfo.email}`}
                class="text-sm hover:text-unag-green transition-colors"
                >{rectorInfo.email}</a
              >
            </div>
          </div>
        </div>

        <!-- Main Content / Message Section -->
        <div class="lg:col-span-8 p-8 lg:p-12 dark:bg-unag-dark-green">
          <div class="mb-8">
            <div class="flex items-start gap-4 mb-6">
              <Quote className="w-12 h-12 text-unag-green shrink-0" />
              <h3 class="text-3xl font-bold text-gray-800 dark:text-white mt-2">
                Un Académico al Frente de la UNAG
              </h3>
            </div>

            <div class="prose prose-sm text-gray-600 max-w-none space-y-4">
              <p class="leading-relaxed">
                Ingeniero Agrónomo egresado de la Universidad Nacional Autónoma
                de Honduras UNAH sede CURLA (1994), M. Sc. en Agricultura
                Ecológica con énfasis en manejo integrado de plagas, Centro
                Agronómico Tropical de Investigación y Enseñanza (CATIE), Costa
                Rica (2005), Diplomado de Investigación en Universidad de Idaho,
                USA, Ph. D. en Ciencias Agrarias con énfasis en manejo de plagas
                insectiles, Universidad de Bonn, Alemania (2010). Dominio de
                tres idiomas: español, inglés y alemán. Experiencia en
                producción, investigación y docencia por 28 años con organismos
                privados y públicos, en agencias nacionales e internacionales,
                así como para universidades nacionales y del extranjero en áreas
                sobre Manejo Integrado de Plagas Agrícolas (MIP), Entomología y
                Seminario de Investigación para pregrado y postgrado. Autor y
                coautor de publicaciones en revistas científicas como Chemical
                Engineering Cet journal, Plant &amp; Soil, Journal of
                Phytopathology, Biological Control, Journal of Pest Management,
                Journal of Plant Diseases &amp; Protection, Communicative &amp;
                Integrative Biology, Chemical Engineering Transactions, además,
                ponente de trabajos de investigación en eventos internacionales
                como congreso SOCOLEN en Colombia, Tropentag y Deutscher
                Pflanzenschutztagung en Alemania, Workshop en Guangzhou China,
                entre otros.
              </p>
              <p class="leading-relaxed">
                Es profesor de la Facultad de Ciencias Agrarias (FCA) de la
                UNAG, coordinador de Investigación y Posgrado del Doctorado y
                Maestría en Ciencias Agrarias, entre otros cargos desempeñados,
                vice rector de Internacionalización, director de Autoevaluación
                y Acreditación de la Calidad Educativa Superior, director de
                Investigación de la UNAG, jefe del Departamento de Producción
                Vegetal hoy Facultad de Ciencias Agrarias de la UNAG a partir
                del 2001.
              </p>
              <p class="leading-relaxed">
                Experiencia docente desde 1994 hasta la fecha en tres
                universidades públicas (la UNAG, Centro Universitario Regional
                del Litoral Atlántico (CURLA / UNAH), La Ceiba, Atlántida y el
                Centro Universitario Regional Nor-Oriental (CURNO / UNAH),
                Juticalpa, Honduras), una privada en Honduras (Universidad José
                Cecilio del Valle, Tegucigalpa, Honduras) y en la Universidad
                Nacional de Colombia (UNAL sede Palmira). Consultor privado para
                DICTA, ACDI y GIZ. Investigador activo para las redes
                internacionales CYTED y FONTAGRO.
              </p>
            </div>
          </div>

          <div
            class="mt-12 pt-8 border-t border-gray-100 dark:border-unag-green flex items-center justify-between"
          >
            <div class="flex flex-col">
              <span
                class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-widest font-bold"
                >Gestión Rectoral</span
              >
              <span
                class="text-xl font-bold text-unag-dark-green dark:text-unag-light-green"
                >2026 - 2029</span
              >
            </div>

            <!-- <div
              class="h-16 w-40 bg-gray-50 rounded flex items-center justify-center text-xs text-gray-300 italic border border-dashed border-gray-200"
            >
              Firma del Rector
            </div> -->
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
